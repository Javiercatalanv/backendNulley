# =====================================================
# Application
# =====================================================
PORT=3001
NODE_ENV=development

# =====================================================
# PostgreSQL — relational storage
# (these values match the docker-compose.yml shipped
#  with the project; don't change unless you also change docker-compose)
# =====================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=research_publications

# =====================================================
# MongoDB — schemaless audit storage
# =====================================================
MONGO_URI=mongodb://localhost:27017/research_imports

# =====================================================
# Web of Science Starter API (Clarivate)
# Apply at https://developer.clarivate.com with your @ucn.cl email.
# Leave EMPTY until approved — the WoS endpoints will simply return
# a 500 with a clear message when this key is missing.
# =====================================================
WOS_API_KEY=<YOURAPIKEYHERE>

# =====================================================
# Scopus Search API (Elsevier)
# Apply at https://dev.elsevier.com from the UCN network with your
# @ucn.cl or @alumnos.ucn.cl email.
# Paste your key here once you have it.
# =====================================================
SCOPUS_API_KEY=<YOURAPIKEYHERE>

# =====================================================
# Scimago Journal Rank CSV
# Defaults to ./data/scimago_journal_rank.csv if unset.
# Download from https://www.scimagojr.com/journalrank.php
# (button "Download data" at the top-right)
# =====================================================
# SCIMAGO_CSV_PATH=./data/scimago_journal_rank.csv
